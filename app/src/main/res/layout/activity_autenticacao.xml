<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medlife_surface_variant">

    <!-- Gradient Header Area -->
    <View
        android:id="@+id/headerGradient"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_login_header"
        app:layout_constraintHeight_percent="0.4"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/logoImage"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/logo_small"
        app:layout_constraintBottom_toBottomOf="@id/headerGradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerGradient" />

    <!-- Main Content Card -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-40dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerGradient">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/white">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/receba_seus_rem_dios_sem_sair_de_casa"
                    android:textAppearance="@style/TextAppearance.Medlife.Headline1"
                    android:textAlignment="center"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/taglineText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/sempre_que_precisar_estarei_l_medlife_cuidando_do_seu_bem_estar"
                    android:textAppearance="@style/TextAppearance.Medlife.Body2"
                    android:textAlignment="center"
                    app:layout_constraintTop_toBottomOf="@id/titleText" />

                <!-- Email Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailInputLayout"
                    style="@style/Widget.Medlife.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:hint="@string/email"
                    app:layout_constraintTop_toBottomOf="@id/taglineText"
                    app:startIconDrawable="@drawable/baseline_login_24"
                    app:startIconTint="@color/medlife_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editCadastroEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:textAppearance="@style/TextAppearance.Medlife.Body1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordInputLayout"
                    style="@style/Widget.Medlife.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/senha"
                    app:layout_constraintTop_toBottomOf="@id/emailInputLayout"
                    app:passwordToggleEnabled="true"
                    app:startIconDrawable="@drawable/baseline_login_24"
                    app:startIconTint="@color/medlife_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editCadastroSenha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textAppearance="@style/TextAppearance.Medlife.Body1" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/forgotPasswordLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/esqueceu_senha"
                    android:textAppearance="@style/TextAppearance.Medlife.Link"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/passwordInputLayout" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonAcesso"
                    style="@style/Widget.Medlife.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/entrar_com_medlife"
                    app:layout_constraintTop_toBottomOf="@id/forgotPasswordLink" />

                <LinearLayout
                    android:id="@+id/socialHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/buttonAcesso">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_border_color" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp"
                        android:text="Ou conecte com"
                        android:textAppearance="@style/TextAppearance.Medlife.Caption" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@color/input_border_color" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/googleButton"
                    style="@style/Widget.Medlife.Button.Social"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="16dp"
                    android:text="@string/continuar_com_google"
                    app:icon="@drawable/icons8_google_36"
                    app:iconTint="@null"
                    app:layout_constraintTop_toBottomOf="@id/socialHeader" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/facebookButton"
                    style="@style/Widget.Medlife.Button.Social"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="12dp"
                    android:text="@string/continuar_com_facebook"
                    app:icon="@drawable/icons8_facebook_36"
                    app:iconTint="@null"
                    app:layout_constraintTop_toBottomOf="@id/googleButton" />

                <TextView
                    android:id="@+id/registerLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/registrar_se"
                    android:textAppearance="@style/TextAppearance.Medlife.Link"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/facebookButton" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="160dp"
    android:layout_height="260dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/imageProduct"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:padding="16dp"
            android:src="@drawable/logo_small"
            app:layout_constraintHeight_percent="0.55"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/favoriteIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_margin="8dp"
            android:background="@drawable/bg_card_elevated"
            android:backgroundTint="#80FFFFFF"
            android:padding="6dp"
            android:src="@drawable/ic_favorite"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/medlife_error" />

        <!-- Badges (Hidden by default, shown via code or tools:visibility) -->
        <TextView
            android:id="@+id/prescriptionBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/bg_badge_prescription"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Tarja Preta"
            android:textAppearance="@style/TextAppearance.Medlife.Caption"
            android:textColor="@color/medlife_error"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/promoBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@drawable/bg_badge_promo"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="-15%"
            android:textAppearance="@style/TextAppearance.Medlife.Caption"
            android:textColor="@color/medlife_primary"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/imageProduct"
            app:layout_constraintStart_toStartOf="parent"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/textProductName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:text="@string/nome_do_produto"
            android:textAppearance="@style/TextAppearance.Medlife.Body2"
            android:textStyle="bold"
            android:textColor="@color/medlife_on_surface"
            app:layout_constraintTop_toBottomOf="@id/imageProduct" />

        <TextView
            android:id="@+id/textProductDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingHorizontal="12dp"
            android:text="@string/descri_o_do_produto"
            android:textAppearance="@style/TextAppearance.Medlife.Caption"
            app:layout_constraintTop_toBottomOf="@id/textProductName" />

        <TextView
            android:id="@+id/textProductPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingBottom="12dp"
            android:text="R$ 4,99"
            android:textAppearance="@style/TextAppearance.Medlife.SectionTitle"
            android:textColor="@color/medlife_on_surface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/addButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:backgroundTint="@color/medlife_primary"
            app:fabSize="mini"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_add_white"
            app:tint="@color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView> 
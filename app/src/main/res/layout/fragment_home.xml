<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medlife_surface_variant"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp">

        <!-- Top Bar -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/logoSmall"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logo_small"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/locationBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sua localização"
                    android:textAppearance="@style/TextAppearance.Medlife.Caption" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/medlife_primary" />

                    <TextView
                        android:id="@+id/locationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Campinas, SP"
                        android:textAppearance="@style/TextAppearance.Medlife.Body2"
                        android:textStyle="bold"
                        android:textColor="@color/medlife_on_surface" />
                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:id="@+id/notificationBell"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/baseline_login_24"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/medlife_on_surface" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Search Bar -->
        <androidx.cardview.widget.CardView
            android:id="@+id/searchBar"
            style="@style/Widget.Medlife.Card"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="8dp"
            app:cardCornerRadius="27dp"
            app:cardElevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/topBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home_search"
                    app:tint="@color/medlife_on_surface_variant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Buscar remédios ou farmácia"
                    android:textAppearance="@style/TextAppearance.Medlife.Body2" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hero Banner Slot -->
        <androidx.cardview.widget.CardView
            android:id="@+id/bannerCard"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/medlife_primary_container"
            app:layout_constraintTop_toBottomOf="@id/searchBar">
            
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/bg_header_gradient"
                android:alpha="0.1"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Banner Promocional"
                android:textAppearance="@style/TextAppearance.Medlife.SectionTitle"
                android:textColor="@color/medlife_primary" />
        </androidx.cardview.widget.CardView>

        <!-- Categories Section -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subcategoriesRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toBottomOf="@id/bannerCard"
            tools:listitem="@layout/item_product" />

        <!-- Exclusive Offers Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/exclusiveHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/subcategoriesRecycler">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ofertas Exclusivas"
                android:textAppearance="@style/TextAppearance.Medlife.SectionTitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/seeAllOffers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver tudo"
                android:textAppearance="@style/TextAppearance.Medlife.Link"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/exclusiveOffersRecycler"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/exclusiveHeader" />

        <!-- Best Selling Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bestSellingHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/exclusiveOffersRecycler">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mais Vendidos"
                android:textAppearance="@style/TextAppearance.Medlife.SectionTitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/seeAllBestSelling"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver tudo"
                android:textAppearance="@style/TextAppearance.Medlife.Link"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bestSellingRecycler"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/bestSellingHeader" />

        <!-- Medicamentos Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/medicamentosHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toBottomOf="@id/bestSellingRecycler">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medicamentos"
                android:textAppearance="@style/TextAppearance.Medlife.SectionTitle"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/seeAllMedicamentos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ver tudo"
                android:textAppearance="@style/TextAppearance.Medlife.Link"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/medicamentosRecycler"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="12dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toBottomOf="@id/medicamentosHeader" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
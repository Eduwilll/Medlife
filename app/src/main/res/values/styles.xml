<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base button style for primary actions -->
    <style name="Widget.Medlife.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">16dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">4dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Outlined button style -->
    <style name="Widget.Medlife.Button.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/medlife_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/medlife_primary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Social Login Buttons -->
    <style name="Widget.Medlife.Button.Social" parent="Widget.Medlife.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">12dp</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
        <item name="strokeColor">@color/input_border_color</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Text appearances -->
    <style name="TextAppearance.Medlife.HeadlineXL" parent="TextAppearance.MaterialComponents.Headline3">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Medlife.Headline1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Medlife.SectionTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Medlife.Body1" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
    </style>

    <style name="TextAppearance.Medlife.Body2" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/medlife_on_surface_variant</item>
    </style>

    <style name="TextAppearance.Medlife.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/medlife_on_surface_variant</item>
    </style>

    <style name="TextAppearance.Medlife.Link" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/medlife_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Card Styles -->
    <style name="Widget.Medlife.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/medlife_surface</item>
    </style>

    <!-- Input Field Styles -->
    <style name="Widget.Medlife.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/medlife_primary</item>
    </style>

    <style name="FilterCheckBox" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:fontFamily">@font/gilroymedium</item>
        <item name="android:textColor">@color/medlife_on_surface</item>
        <item name="buttonTint">@color/medlife_primary</item>
    </style>

    <style name="FilterButton" parent="Widget.Medlife.Button">
        <item name="android:layout_margin">25dp</item>
    </style>

    <style name="BottomNavigationText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/gilroymedium</item>
    </style>

    <style name="ReviewStar">
        <item name="android:layout_width">16dp</item>
        <item name="android:layout_height">16dp</item>
        <item name="android:layout_marginEnd">2dp</item>
    </style>
</resources>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Medlife" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/medlife_primary</item>
        <item name="colorPrimaryVariant">@color/medlife_primary_light</item>
        <item name="colorOnPrimary">@color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/medlife_accent</item>
        <item name="colorSecondaryVariant">@color/medlife_accent</item>
        <item name="colorOnSecondary">@color/white</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/medlife_primary</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Background colors -->
        <item name="android:colorBackground">@color/medlife_surface_variant</item>
        <item name="colorSurface">@color/medlife_surface</item>
        <item name="colorOnSurface">@color/medlife_on_surface</item>
        <item name="colorError">@color/medlife_error</item>

        <!-- Text appearances -->
        <item name="textAppearanceHeadline1">@style/TextAppearance.Medlife.HeadlineXL</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.Medlife.SectionTitle</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Medlife.Body1</item>
        <item name="textAppearanceBody2">@style/TextAppearance.Medlife.Body2</item>

        <!-- Button styles -->
        <item name="materialButtonStyle">@style/Widget.Medlife.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Medlife.Button.OutlinedButton</item>

        <!-- TextInputLayout styling -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense</item>
        <item name="boxStrokeColor">@color/medlife_primary</item>
        <item name="hintTextColor">@color/medlife_on_surface_variant</item>
        <item name="android:textColorHint">@color/medlife_on_surface_variant</item>
    </style>

    <!-- NoActionBar theme variant -->
    <style name="Theme.Medlife.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
</resources>